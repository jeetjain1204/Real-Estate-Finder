# Streamlit Cloud secrets template
# ---
# Copy EVERYTHING below into: share.streamlit.io → your app → ⋮ → Settings → Secrets.
# Use flat keys only (as shown). Do not commit a real secrets.toml.
#
# Local dev: use .env + python-dotenv instead.

GOOGLE_API_KEY = "your_google_ai_studio_key_here"
GEMINI_MODEL = "gemini-1.5-flash"

# Persistence on Cloud: Neon (https://neon.tech) or any Postgres.
# compile_graph() accepts either variable name:
POSTGRES_CONNECTION_STRING = "postgresql://user:password@host/db?sslmode=require"
# DATABASE_URL = "postgresql://user:password@host/db?sslmode=require"

# SQLite fallback on Cloud (state resets on restart). Omit when using Postgres above.
# REALESTATE_CHECKPOINT_DB = "/tmp/checkpoints.sqlite"

# LangSmith — optional
LANGSMITH_API_KEY = "your_langsmith_api_key_here"
LANGSMITH_TRACING_V2 = "true"
LANGSMITH_PROJECT = "realestate-finder"
