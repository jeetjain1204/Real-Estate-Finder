# Streamlit Cloud secrets template
# ---
# Copy this file's contents into the Streamlit Cloud dashboard under
# App settings > Secrets (do NOT rename/commit this file as secrets.toml).
#
# For local development, use .env instead — python-dotenv loads it automatically.

GOOGLE_API_KEY = "your_google_ai_studio_key_here"
GEMINI_MODEL = "gemini-1.5-flash"

# Neon PostgreSQL — free serverless Postgres, required for cloud persistence
# Create a database at https://neon.tech and paste the connection string below.
POSTGRES_CONNECTION_STRING = "postgresql://user:password@host/db?sslmode=require"

# LangSmith tracing — optional; enables run observability at smith.langchain.com
LANGSMITH_API_KEY = "your_langsmith_api_key_here"
LANGSMITH_TRACING_V2 = "true"
LANGSMITH_PROJECT = "realestate-finder"
