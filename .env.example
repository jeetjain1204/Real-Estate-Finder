GOOGLE_API_KEY=your_google_ai_studio_key_here
GEMINI_MODEL=gemini-1.5-flash

# Local SQLite checkpoint (used when POSTGRES_CONNECTION_STRING is not set)
REALESTATE_CHECKPOINT_DB=data/checkpoints.sqlite

# LangSmith tracing (optional — enables observability in LangSmith dashboard)
# Get your key at https://smith.langchain.com
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_TRACING_V2=true
LANGSMITH_PROJECT=realestate-finder

# PostgreSQL checkpointer for Streamlit Cloud (optional — omit for local dev)
# Get a free serverless Postgres database at https://neon.tech
# POSTGRES_CONNECTION_STRING=postgresql://user:password@host/db?sslmode=require
