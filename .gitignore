# Secret keys — NEVER commit the real .env file.
# Copy .env.example to .env and fill in your keys.
.env

# Virtual environments
.venv/
venv/

# Python bytecode
__pycache__/
*.pyc
*.pyo

# Streamlit secrets (API keys)
.streamlit/secrets.toml

# SQLite checkpoints — contain buyer state; excluded from version control.
# The data/ directory itself is tracked (see data/.gitkeep).
data/*.sqlite
data/*.sqlite-*
data/*.db

# Pytest cache
.pytest_cache/

# IDE
.vscode/
.idea/
